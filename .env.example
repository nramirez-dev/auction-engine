# PostgreSQL — used by docker-compose to create the database
POSTGRES_DB=auction
POSTGRES_USER=auction_user
POSTGRES_PASSWORD=change_me

# Redis — used by docker-compose to set the password
REDIS_PASS=change_me

# App DB connection — must match POSTGRES_* values above
DB_HOST=postgres
DB_PORT=5432
DB_NAME=auction
DB_USER=auction_user
DB_PASS=change_me

# App Redis connection — must match REDIS_PASS above
REDIS_HOST=redis
REDIS_PORT=6379

# Application
SECRET_KEY=change_me_in_production
DEBUG=false

# Alembic — required; constructed from DB_* values above
DATABASE_URL=postgresql+asyncpg://auction_user:change_me@postgres:5432/auction
